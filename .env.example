# ============================================================================
# Rising You — Omgevingsvariabelen (voorbeeld)
# ----------------------------------------------------------------------------
# Kopieer dit bestand naar ".env" en vul de echte waarden in.
# Het .env-bestand zelf hoort NIET in versiebeheer (staat in .gitignore).
#
# Je vindt deze waarden in je Supabase-project onder:
#   Project Settings  ->  API
# ============================================================================

# De URL van je Supabase-project (bv. https://abcdxyz.supabase.co)
VITE_SUPABASE_URL=

# De publieke "anon"-sleutel. Deze mag in de client staan; de echte
# beveiliging gebeurt via Row Level Security in de database.
VITE_SUPABASE_ANON_KEY=
