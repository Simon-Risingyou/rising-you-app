{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rising You Ledenbeheer",
  "version": "0.1.0",
  "identifier": "be.risingyou.ledenbeheer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Rising You — Ledenbeheer",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' data: blob: https://*.supabase.co; style-src 'self' 'unsafe-inline'; frame-src 'self' blob:; object-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "wix": { "language": "nl-BE" }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/JOUW_GEBRUIKERSNAAM/rising-you-ledenbeheer/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "HIER_KOMT_JE_PUBLIEKE_UPDATE_SLEUTEL"
    }
  }
}
